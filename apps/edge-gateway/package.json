{
  "name": "@cummins-os/edge-gateway",
  "version": "0.1.0",
  "description": "Cummins OS - Industrial Edge Gateway (Node.js/Express)",
  "private": true,
  "scripts": {
    "dev": "ts-node src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules coverage"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "mqtt": "^5.3.2",
    "pino": "^8.16.2",
    "pino-http": "^8.5.0",
    "uuid": "^9.0.1",
    "ws": "^8.15.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
