# ==============================================================================
# CUMMINS OS - Environment Configuration Template
# ==============================================================================

# Application
NODE_ENV=development
APP_NAME=cummins-os
APP_VERSION=0.1.0

# ==============================================================================
# API CONFIGURATION
# ==============================================================================
API_PORT=3001
API_HOST=0.0.0.0
API_LOG_LEVEL=debug

# ==============================================================================
# DATABASE
# ==============================================================================
# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=cummins_os
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false

# TimescaleDB (Telemetry)
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_NAME=cummins_telemetry
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=postgres

# ==============================================================================
# REDIS
# ==============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==============================================================================
# MESSAGE QUEUE - KAFKA
# ==============================================================================
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=cummins-os-consumer

# Kafka Topics
KAFKA_TELEMETRY_TOPIC=cummins.telemetry.raw
KAFKA_DIAGNOSTICS_TOPIC=cummins.diagnostics.events
KAFKA_ALERTS_TOPIC=cummins.alerts.events
KAFKA_COMMANDS_TOPIC=cummins.fleet.commands

# ==============================================================================
# AUTHENTICATION & SECURITY
# ==============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3000:443

# ==============================================================================
# INDUSTRIAL PROTOCOLS
# ==============================================================================
# MQTT Configuration
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_BROKER_PROTOCOL=mqtt
MQTT_USERNAME=
MQTT_PASSWORD=

# MQTT Topics
MQTT_TELEMETRY_TOPIC=fleet/+/telemetry
MQTT_COMMANDS_TOPIC=fleet/+/commands/+
MQTT_DIAGNOSTICS_TOPIC=fleet/+/diagnostics

# OPC-UA Configuration
OPCUA_ENDPOINT=opc.tcp://localhost:4334
OPCUA_USERNAME=
OPCUA_PASSWORD=

# CAN Bus Configuration (Edge Gateway)
CAN_INTERFACE=can0
CAN_BITRATE=500000

# ==============================================================================
# EXTERNAL SERVICES
# ==============================================================================
# Elasticsearch/OpenSearch (for diagnostics search)
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_PROTOCOL=http
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ==============================================================================
# OBSERVABILITY
# ==============================================================================
# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=

# Prometheus Metrics
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_HOST=http://localhost:3000
GRAFANA_API_KEY=

# ==============================================================================
# EDGE GATEWAY CONFIGURATION
# ==============================================================================
EDGE_GATEWAY_ID=edge-gateway-001
EDGE_GATEWAY_PORT=4000
EDGE_GATEWAY_NAME=Industrial Edge Gateway
EDGE_SYNC_INTERVAL=30000

# ==============================================================================
# AI/ML CONFIGURATION
# ==============================================================================
AI_SERVICE_URL=http://localhost:8000
AI_API_KEY=

# Model Paths
PREDICTIVE_MODEL_PATH=/models/predictive_maintenance
ANOMALY_MODEL_PATH=/models/anomaly_detection
RUL_MODEL_PATH=/models/rul_estimation

# ==============================================================================
# AWS CONFIGURATION (for production)
# ==============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=cummins-os-data

# ==============================================================================
# THIRD-PARTY INTEGRATIONS
# ==============================================================================
# ServiceNow
SERVICENOW_INSTANCE_URL=
SERVICENOW_CLIENT_ID=
SERVICENOW_CLIENT_SECRET=

# SAP
SAP_HOST=
SAP_PORT=
SAP_USER=
SAP_PASSWORD=

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
FEATURE_DIGITAL_TWINS=true
FEATURE_AUTONOMOUS_OPS=false
FEATURE_HYDROGEN_SYSTEMS=true
FEATURE_ELECTRIFICATION=true
FEATURE_PREDICTIVE_MAINTENANCE=true

# ==============================================================================
# MONITORING & ALERTING
# ==============================================================================
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_FROM=alerts@cummins-os.com
ALERT_SLACK_ENABLED=false
ALERT_SLACK_WEBHOOK_URL=

# ==============================================================================
# LOGGING
# ==============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=./logs
