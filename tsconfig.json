{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "@cummins-os/api/*": ["apps/api/src/*"],
      "@cummins-os/web/*": ["apps/web/src/*"],
      "@cummins-os/edge-gateway/*": ["apps/edge-gateway/src/*"],
      "@cummins-os/types/*": ["packages/types/src/*"],
      "@cummins-os/ui/*": ["packages/ui/src/*"],
      "@cummins-os/db/*": ["packages/db/src/*"],
      "@cummins-os/auth/*": ["packages/auth/src/*"],
      "@cummins-os/observability/*": ["packages/observability/src/*"],
      "@cummins-os/config/*": ["packages/config/src/*"],
      "@cummins-os/integrations/*": ["packages/integrations/src/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["apps/**/*.ts", "packages/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
